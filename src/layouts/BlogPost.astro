---
import BaseLayout from './BaseLayout.astro'
import { TAG_COLORS } from '../lib/tags'

interface Props {
  title: string
  description: string
  date: Date
  tags: string[]
}
const { title, description, date, tags } = Astro.props

const formatted = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
---
<BaseLayout title={title} description={description}>
  <article>
    <!-- Hero -->
    <div style="background: linear-gradient(135deg, var(--surface) 0%, #fce7f3 50%, var(--surface-2) 100%); padding: 4rem 0 3rem; margin-bottom: 3rem;">
      <div class="container">
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem;">
          {tags.map(tag => (
            <span class={`tag ${TAG_COLORS[tag] ?? ''}`}>{tag}</span>
          ))}
        </div>
        <h1 style="color: var(--text); max-width: 20ch; margin-bottom: 1rem;">{title}</h1>
        <p style="font-size: 1.125rem; color: var(--muted); max-width: 52ch; margin-bottom: 1.5rem;">{description}</p>
        <time style="font-size: 0.85rem; color: var(--muted); font-weight: 500;">{formatted}</time>
      </div>
    </div>

    <!-- Body -->
    <div class="container">
      <div class="prose">
        <slot />
      </div>

      <!-- Back link -->
      <div style="margin-top: 4rem; padding-top: 2rem; border-top: 2px solid var(--border);">
        <a href="/blog" style="display: inline-flex; align-items: center; gap: 0.4rem; font-weight: 600; color: var(--primary);">
          ← All posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
